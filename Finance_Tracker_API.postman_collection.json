{
  "info": {
    "name": "Finance Tracker API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://finance-tracker-dsah.onrender.com",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"SecurePass123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/auth/register/", "host": ["{{base_url}}"], "path": ["api", "auth", "register", ""] }
          }
        },
        {
          "name": "Login (Get Token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["const jsonData = pm.response.json();", "pm.collectionVariables.set('token', jsonData.token);"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"SecurePass123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/auth/login/", "host": ["{{base_url}}"], "path": ["api", "auth", "login", ""] }
          }
        }
      ]
    },
    {
      "name": "Expenses",
      "item": [
        {
          "name": "List Expenses",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": { "raw": "{{base_url}}/api/expenses/", "host": ["{{base_url}}"], "path": ["api", "expenses", ""] }
          }
        },
        {
          "name": "Create Expense",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Groceries\",\n  \"amount\": 45.99,\n  \"category\": \"Food\",\n  \"date\": \"2026-04-19\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/expenses/", "host": ["{{base_url}}"], "path": ["api", "expenses", ""] }
          }
        },
        {
          "name": "Filter by Month",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": { "raw": "{{base_url}}/api/expenses/?year=2026&month=4", "host": ["{{base_url}}"], "path": ["api", "expenses", ""], "query": [{ "key": "year", "value": "2026" }, { "key": "month", "value": "4" }] }
          }
        }
      ]
    },
    {
      "name": "Income",
      "item": [
        {
          "name": "List Income",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": { "raw": "{{base_url}}/api/incomes/", "host": ["{{base_url}}"], "path": ["api", "incomes", ""] }
          }
        },
        {
          "name": "Create Income",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Salary\",\n  \"amount\": 3500.00,\n  \"category\": \"Salary\",\n  \"date\": \"2026-04-19\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/incomes/", "host": ["{{base_url}}"], "path": ["api", "incomes", ""] }
          }
        }
      ]
    },
    {
      "name": "Bills",
      "item": [
        {
          "name": "List Bills",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": { "raw": "{{base_url}}/api/bills/", "host": ["{{base_url}}"], "path": ["api", "bills", ""] }
          }
        },
        {
          "name": "Create Bill",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Rent\",\n  \"amount\": 1200.00,\n  \"due_date\": \"2026-05-01\",\n  \"reminder_days_before\": 3\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/bills/", "host": ["{{base_url}}"], "path": ["api", "bills", ""] }
          }
        },
        {
          "name": "Mark Bill Paid",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": { "raw": "{{base_url}}/api/bills/1/mark_paid/", "host": ["{{base_url}}"], "path": ["api", "bills", "1", "mark_paid", ""] }
          }
        }
      ]
    },
    {
      "name": "Goals",
      "item": [
        {
          "name": "List Goals",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": { "raw": "{{base_url}}/api/goals/", "host": ["{{base_url}}"], "path": ["api", "goals", ""] }
          }
        },
        {
          "name": "Create Goal",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New Laptop\",\n  \"target_amount\": 1500.00,\n  \"deadline\": \"2026-12-31\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/goals/", "host": ["{{base_url}}"], "path": ["api", "goals", ""] }
          }
        }
      ]
    },
    {
      "name": "Dashboard Summary",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
        "url": { "raw": "{{base_url}}/api/dashboard/summary/", "host": ["{{base_url}}"], "path": ["api", "dashboard", "summary", ""] }
      }
    },
    {
      "name": "Currencies (Public)",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{base_url}}/api/currencies/", "host": ["{{base_url}}"], "path": ["api", "currencies", ""] }
      }
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "List Notifications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": { "raw": "{{base_url}}/api/notifications/", "host": ["{{base_url}}"], "path": ["api", "notifications", ""] }
          }
        },
        {
          "name": "Mark as Read",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": { "raw": "{{base_url}}/api/notifications/1/mark_read/", "host": ["{{base_url}}"], "path": ["api", "notifications", "1", "mark_read", ""] }
          }
        },
        {
          "name": "Mark All Read",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": { "raw": "{{base_url}}/api/notifications/mark_all_read/", "host": ["{{base_url}}"], "path": ["api", "notifications", "mark_all_read", ""] }
          }
        }
      ]
    }
  ]
}